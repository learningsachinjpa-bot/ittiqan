# ── Core ──────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/ittiqan
SECRET_KEY=change-me-to-a-random-64-char-string
ENCRYPTION_KEY=change-me-to-a-32-char-fernet-key
GOOGLE_CLIENT_ID=your-google-oauth-client-id
FRONTEND_URL=http://localhost:3000

# ── Cache ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Email / SMTP (optional — email is silently skipped if not set) ────────────
# Gmail example (create an App Password at myaccount.google.com/apppasswords):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=yourapp@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=Ittiqan <yourapp@gmail.com>
# SMTP_USE_TLS=true
#
# SendGrid example:
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASSWORD=SG.your-sendgrid-api-key
# SMTP_FROM=Ittiqan <noreply@yourdomain.com>
#
# AWS SES (SMTP interface):
# SMTP_HOST=email-smtp.us-east-1.amazonaws.com
# SMTP_PORT=587
# SMTP_USER=AKIAIOSFODNN7EXAMPLE
# SMTP_PASSWORD=your-ses-smtp-password
# SMTP_FROM=Ittiqan <noreply@yourdomain.com>

# ── Stripe (optional — billing features disabled if not set) ──────────────────
# Get these from https://dashboard.stripe.com/apikeys and https://dashboard.stripe.com/products
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...   # from Stripe CLI: stripe listen --print-secret
# STRIPE_PRO_PRICE_ID=price_...     # monthly Pro price ID
# STRIPE_ENTERPRISE_PRICE_ID=price_...  # optional enterprise price ID
