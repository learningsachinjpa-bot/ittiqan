# ── Ittiqan Backend — Environment Variables ──────────────────────────────────
# Copy this to .env and fill in real values. NEVER commit .env to git.
# Generate SECRET_KEY and ENCRYPTION_KEY with:
#   python -c "import secrets; print(secrets.token_hex(32))"

DATABASE_URL=postgresql://postgres:CHANGE_ME@localhost:5432/ittiqan
SECRET_KEY=GENERATE_WITH_secrets.token_hex(32)
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
REDIS_URL=redis://localhost:6379
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
# Comma-separated list of allowed frontend origins — no trailing slashes
FRONTEND_URL=https://your-domain.com
ENCRYPTION_KEY=GENERATE_WITH_secrets.token_hex(32)
